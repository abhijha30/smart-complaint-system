if path == "/api/login":
    res = supabase.table("users").select("*")\
        .eq("email", body["email"])\
        .eq("password", body["password"]).execute()

    if res.data:
        return self.respond({
            "message": "Login Success",
            "role": res.data[0]["role"]
        })
    return self.respond({"message": "Invalid"}, 401)
